# ==============================================================================
# ReconX .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual Environments
.venv/
venv/
ENV/
env/

# Databases & scan data
*.db
*.db-shm
*.db-wal
output/
results/

# Logs
logs/
*.log

# Secrets — NEVER commit real keys
.env
*.key
secrets.txt
config/api_keys_local.yaml

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Test artefacts
.pytest_cache/
.coverage
htmlcov/
test_*.db

# Temp
*.tmp
*.temp
tmp/
temp/

# ==============================================================================
# Repo-specific exclusions
# ==============================================================================

# Archived legacy code (not deleted, just moved)
# archive/ is committed intentionally

# Test artifacts
test.db
/tmp/unref_*.txt

# Alembic
alembic/versions/*.pyc

# Docker build cache
.docker/

# CI/CD generated
.github/workflows/__pycache__/

# Backup & generated docs
*.bak
docs/*.bak
*.pdf
*.tmp.html
progress_docs/

# Planning / prompt files (internal)
ALL_REMAINING_PROMPTS.md
CLAUDE_SONNET_FIX_PROMPTS.md
CLEANUP_REPORT.md
COPY_PASTE_PROMPTS.md
CRITICAL_NEXT_STEPS.md
DETAILED_API_PROMPTS.md
DETAILED_DATABASE_PROMPTS.md
DETAILED_INTELLIGENCE_ORCHESTRATOR_PROMPTS.md
MASTER_CLAUDE_PROMPT.md
MASTER_EXECUTION_GUIDE.md
MERGE_COMPLETE_STATUS.md
OPUS_VALIDATION_PROMPT.md
PHASE_ROADMAP_AND_PROMPTS.md
PRODUCTION_READINESS_FIX_PLAN.md
PRODUCTION_READINESS_REPORT.md
QUICK_REFERENCE.md
START_HERE_TODO.md
VALIDATION_REPORT.md
complete_plan.md
