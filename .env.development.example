# ReconX Development Environment
# Copy to .env.development and fill in values before running locally.
# Never commit the .env.development file (it is in .gitignore).

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./reconx.db

# ── API Security ──────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
RECONX_SECRET_KEY=REPLACE_ME_dev_secret_key_32_chars_min

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_POLL_SEC=2
WORKER_MAX_JOBS=1

# ── Scanner ───────────────────────────────────────────────────────────────────
# Set to true to update Nuclei templates before each scan (slow; off by default)
RECONX_NUCLEI_UPDATE=false
