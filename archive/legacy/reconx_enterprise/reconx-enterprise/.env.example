# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database
DATABASE_URL=postgresql://reconx:reconx_dev@localhost:5432/reconx_db
SQLALCHEMY_ECHO=true

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Authentication (Optional)
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256

# API Keys (Third-party Services)
ABUSEIPDB_API_KEY=your-api-key
SHODAN_API_KEY=your-api-key
VIRUSTOTAL_API_KEY=your-api-key
NVD_API_KEY=your-api-key
GITHUB_TOKEN=your-github-token
GITLAB_TOKEN=your-gitlab-token
DEHASHED_EMAIL=your-email
DEHASHED_API_KEY=your-key
OPENPHISH_API_KEY=your-api-key
GREYNOISE_API_KEY=your-api-key
OTX_API_KEY=your-otx-api-key
CROWDSEC_API_KEY=your-key
SPUR_API_TOKEN=your-token
PULSEDIVE_API_KEY=your-key
BINARYEDGE_API_KEY=your-key
THREATMINER_API_KEY=your-key
URLSCAN_API_KEY=your-key
EPSS_API_KEY=your-key
CISA_API_KEY=your-key

# Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@reconx.local
SMTP_TLS=true

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-token

# PagerDuty Integration (Optional)
PAGERDUTY_API_KEY=your-api-key
PAGERDUTY_SERVICE_ID=your-service-id

# Webhook Secret
WEBHOOK_SECRET=your-webhook-secret

# Logging
LOG_FILE=logs/app.log
LOG_FORMAT=json
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Scanning Configuration
SCAN_TIMEOUT=3600
SCAN_MAX_PARALLEL=5
SCAN_DEFAULT_INTENSITY=normal

# Compliance
COMPLIANCE_FRAMEWORKS=pci,hipaa,nist,gdpr,soc2
PCI_DSS_VERSION=4.0
NIST_CSF_VERSION=2.0

# ML Models (Optional)
ML_MODELS_ENABLED=false
ML_MODELS_PATH=./data/ml_models
SKLEARN_VERBOSITY=0

# Threat Intelligence
THREAT_INTEL_UPDATE_INTERVAL=3600
THREAT_INTEL_CACHE_DIR=./cache/threat_intel

# Development Settings (Only for dev/testing)
MOCK_API_RESPONSES=true
SKIP_EXTERNAL_API_CALLS=false
TEST_DATABASE_URL=sqlite:///./test.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL (for frontend API calls)
BACKEND_URL=http://localhost:8000
