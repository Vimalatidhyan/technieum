# ReconX Production Environment
# Copy to .env.production and fill in all values.
# Store this file in a secrets manager (Vault, AWS Secrets Manager, etc.)
# Never commit the .env.production file.

# ── Database ─────────────────────────────────────────────────────────────────
# For production use PostgreSQL:
#   DATABASE_URL=postgresql+psycopg2://user:password@db-host:5432/reconx
DATABASE_URL=postgresql+psycopg2://reconx:REPLACE_ME@db-host:5432/reconx

# ── API Security ──────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
RECONX_SECRET_KEY=REPLACE_ME_production_secret_key_minimum_32_chars

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_POLL_SEC=5
WORKER_MAX_JOBS=4

# ── Scanner ───────────────────────────────────────────────────────────────────
RECONX_NUCLEI_UPDATE=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcards in production)
RECONX_ALLOWED_ORIGINS=https://your-domain.example.com
