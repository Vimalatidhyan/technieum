#!/bin/bash
################################################################################
# Technieum - Phase 1: Horizontal & Vertical Discovery
# Comprehensive subdomain enumeration using ALL tools
################################################################################

set -e
TARGET="$1"
OUTPUT_DIR="$2"

if [ -z "$TARGET" ] || [ -z "$OUTPUT_DIR" ]; then
    echo "Usage: $0 <target> <output_dir>"
    exit 1
fi

PHASE_DIR="$OUTPUT_DIR/phase1_discovery"
mkdir -p "$PHASE_DIR"

echo "[*] Phase 1: Discovery & Enumeration for $TARGET"
echo "[*] Output directory: $PHASE_DIR"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[+]${NC} $1"
}

log_error() {
    echo -e "${RED}[-]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[!]${NC} $1"
}

run_tool() {
    local tool_name="$1"
    local output_file="$2"
    shift 2
    local cmd="$@"

    if command -v "$tool_name" &> /dev/null; then
        log_info "Running $tool_name..."
        if eval "$cmd" 2>"${output_file}.err"; then
            log_info "$tool_name completed"
            return 0
        else
            log_error "$tool_name failed (see ${output_file}.err)"
            return 1
        fi
    else
        log_warn "$tool_name not installed, skipping..."
        return 1
    fi
}

################################################################################
# PHASE 1A: HORIZONTAL DISCOVERY (Acquisitions)
################################################################################

log_info "=== HORIZONTAL DISCOVERY ==="

# Whois domain information
if command -v whois &> /dev/null; then
    log_info "Running whois..."
    whois "$TARGET" > "$PHASE_DIR/whois.txt" 2>/dev/null || log_warn "Whois failed"
else
    log_warn "whois not found"
fi

# Amass Intel mode for ASN/Org discovery
run_tool "amass" "$PHASE_DIR/amass_intel.txt" \
    "amass intel -d $TARGET -whois -timeout 10 -o $PHASE_DIR/amass_intel.txt"

# Get subsidiaries (if tool exists)
if [ -f "/opt/getSubsidiaries/getSubsidiaries.py" ]; then
    log_info "Running getSubsidiaries..."
    python3 /opt/getSubsidiaries/getSubsidiaries.py "$TARGET" > "$PHASE_DIR/subsidiaries.txt" 2>/dev/null || log_warn "getSubsidiaries failed"
else
    log_warn "getSubsidiaries not found"
fi

################################################################################
# PHASE 1B: VERTICAL DISCOVERY (Subdomains)
################################################################################

log_info "=== VERTICAL DISCOVERY (SUBDOMAIN ENUMERATION) ==="

# Create temp directory for individual tool outputs
TEMP_SUBS="$PHASE_DIR/temp_subdomains"
mkdir -p "$TEMP_SUBS"

# Launch all subdomain enumeration tools in parallel
pids=()

# 1. Sublist3r
if command -v sublist3r &> /dev/null || [ -f "/opt/Sublist3r/sublist3r.py" ]; then
    log_info "Launching Sublist3r..."
    (
        if [ -f "/opt/Sublist3r/sublist3r.py" ]; then
            python3 /opt/Sublist3r/sublist3r.py -d "$TARGET" -o "$TEMP_SUBS/sublist3r.txt" 2>/dev/null
        else
            sublist3r -d "$TARGET" -o "$TEMP_SUBS/sublist3r.txt" 2>/dev/null
        fi
    ) &
    pids+=($!)
else
    log_warn "Sublist3r not found"
fi

# 2. OWASP Amass Enum
if command -v amass &> /dev/null; then
    log_info "Launching Amass enum..."
    (
        amass enum -d "$TARGET" -passive -timeout 15 -o "$TEMP_SUBS/amass.txt" 2>/dev/null
    ) &
    pids+=($!)
else
    log_warn "Amass not found"
fi

# 3. Assetfinder
if command -v assetfinder &> /dev/null; then
    log_info "Launching Assetfinder..."
    (
        assetfinder --subs-only "$TARGET" > "$TEMP_SUBS/assetfinder.txt" 2>/dev/null
    ) &
    pids+=($!)
else
    log_warn "Assetfinder not found"
fi

# 4. Subfinder
if command -v subfinder &> /dev/null; then
    log_info "Launching Subfinder..."
    (
        subfinder -d "$TARGET" -silent -o "$TEMP_SUBS/subfinder.txt" 2>/dev/null
    ) &
    pids+=($!)
else
    log_warn "Subfinder not found"
fi

# 5. SubDominator
if command -v subdominator &> /dev/null || [ -f "/opt/SubDominator/SubDominator.py" ]; then
    log_info "Launching SubDominator..."
    (
        if [ -f "/opt/SubDominator/SubDominator.py" ]; then
            python3 /opt/SubDominator/SubDominator.py -d "$TARGET" -o "$TEMP_SUBS/subdominator.txt" 2>/dev/null
        else
            subdominator -d "$TARGET" -o "$TEMP_SUBS/subdominator.txt" 2>/dev/null
        fi
    ) &
    pids+=($!)
else
    log_warn "SubDominator not found"
fi

# 6. crt.sh via curl
log_info "Launching crt.sh..."
(
    curl -s "https://crt.sh/?q=%25.$TARGET&output=json" 2>/dev/null | \
        jq -r '.[].name_value' 2>/dev/null | \
        sed 's/\*\.//g' | \
        sort -u > "$TEMP_SUBS/crtsh.txt"
) &
pids+=($!)

# 7. SecurityTrails (if API key is set)
if [ ! -z "$SECURITYTRAILS_API_KEY" ]; then
    log_info "Launching SecurityTrails..."
    (
        curl -s "https://api.securitytrails.com/v1/domain/$TARGET/subdomains" \
            -H "APIKEY: $SECURITYTRAILS_API_KEY" 2>/dev/null | \
            jq -r '.subdomains[]' 2>/dev/null | \
            awk -v domain="$TARGET" '{print $0"."domain}' > "$TEMP_SUBS/securitytrails.txt"
    ) &
    pids+=($!)
fi

# Wait for all passive enumeration tools to complete
log_info "Waiting for passive enumeration tools to complete..."
for pid in "${pids[@]}"; do
    wait "$pid" 2>/dev/null || true
done

log_info "Passive enumeration completed"

# Merge all subdomain outputs
log_info "Merging subdomain results..."
cat "$TEMP_SUBS"/*.txt 2>/dev/null | \
    grep -E "^[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$" | \
    sort -u > "$PHASE_DIR/passive_subdomains.txt"

PASSIVE_COUNT=$(wc -l < "$PHASE_DIR/passive_subdomains.txt" | tr -d ' ')
log_info "Found $PASSIVE_COUNT unique subdomains from passive enumeration"

################################################################################
# PHASE 1C: ACTIVE SUBDOMAIN DISCOVERY
################################################################################

log_info "=== ACTIVE SUBDOMAIN DISCOVERY ==="

# 8. Dnsbruter (DNS bruteforcing)
if command -v dnsbruter &> /dev/null; then
    log_info "Running Dnsbruter..."
    run_tool "dnsbruter" "$TEMP_SUBS/dnsbruter.txt" \
        "dnsbruter -d $TARGET -w /usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt -o $TEMP_SUBS/dnsbruter.txt"
elif [ -f "/opt/dnsbruter/dnsbruter.py" ]; then
    log_info "Running Dnsbruter (Python)..."
    python3 /opt/dnsbruter/dnsbruter.py -d "$TARGET" -o "$TEMP_SUBS/dnsbruter.txt" 2>/dev/null || log_warn "Dnsbruter failed"
else
    log_warn "Dnsbruter not found"
fi

# 9. Dnsprober (DNS probing)
if command -v dnsprober &> /dev/null && [ -f "$PHASE_DIR/passive_subdomains.txt" ]; then
    log_info "Running Dnsprober..."
    dnsprober -l "$PHASE_DIR/passive_subdomains.txt" -o "$TEMP_SUBS/dnsprober.txt" 2>/dev/null || log_warn "Dnsprober failed"
else
    log_warn "Dnsprober not found or no passive subdomains"
fi

# Merge active results
if [ -f "$TEMP_SUBS/dnsbruter.txt" ] || [ -f "$TEMP_SUBS/dnsprober.txt" ]; then
    cat "$TEMP_SUBS/dnsbruter.txt" "$TEMP_SUBS/dnsprober.txt" 2>/dev/null | \
        grep -E "^[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$" | \
        sort -u > "$PHASE_DIR/active_subdomains.txt"
fi

# Final merge of all subdomains
cat "$PHASE_DIR/passive_subdomains.txt" "$PHASE_DIR/active_subdomains.txt" 2>/dev/null | \
    sort -u > "$PHASE_DIR/all_subdomains.txt"

TOTAL_SUBS=$(wc -l < "$PHASE_DIR/all_subdomains.txt" | tr -d ' ')
log_info "Total unique subdomains found: $TOTAL_SUBS"

################################################################################
# PHASE 1D: DNS RESOLUTION
################################################################################

log_info "=== DNS RESOLUTION ==="

# DNSx for resolution
if command -v dnsx &> /dev/null && [ -f "$PHASE_DIR/all_subdomains.txt" ]; then
    log_info "Running DNSx for resolution..."
    cat "$PHASE_DIR/all_subdomains.txt" | \
        dnsx -silent -a -resp -json -o "$PHASE_DIR/dnsx_resolved.json" 2>/dev/null || log_warn "DNSx failed"

    # Extract resolved domains
    if [ -f "$PHASE_DIR/dnsx_resolved.json" ]; then
        cat "$PHASE_DIR/dnsx_resolved.json" | jq -r '.host' 2>/dev/null | sort -u > "$PHASE_DIR/resolved_subdomains.txt"
    fi
else
    log_warn "DNSx not found, using all subdomains as resolved"
    cp "$PHASE_DIR/all_subdomains.txt" "$PHASE_DIR/resolved_subdomains.txt"
fi

RESOLVED_COUNT=$(wc -l < "$PHASE_DIR/resolved_subdomains.txt" 2>/dev/null | tr -d ' ')
log_info "Resolved subdomains: $RESOLVED_COUNT"

################################################################################
# PHASE 1E: HTTP VALIDATION
################################################################################

log_info "=== HTTP VALIDATION ==="

# HTTPx for live host detection
if command -v httpx &> /dev/null && [ -f "$PHASE_DIR/resolved_subdomains.txt" ]; then
    log_info "Running HTTPx to find alive hosts..."
    cat "$PHASE_DIR/resolved_subdomains.txt" | \
        httpx -silent -json -status-code -follow-redirects -threads 50 -timeout 10 \
        -o "$PHASE_DIR/httpx_alive.json" 2>/dev/null || log_warn "HTTPx failed"

    # Extract alive hosts
    if [ -f "$PHASE_DIR/httpx_alive.json" ]; then
        cat "$PHASE_DIR/httpx_alive.json" | jq -r '.url' 2>/dev/null | \
            sed -E 's|^https?://||' | sed 's|/.*||' | sort -u > "$PHASE_DIR/alive_hosts.txt"

        ALIVE_COUNT=$(wc -l < "$PHASE_DIR/alive_hosts.txt" | tr -d ' ')
        log_info "Alive hosts: $ALIVE_COUNT"
    fi
else
    log_warn "HTTPx not found, skipping live validation"
    cp "$PHASE_DIR/resolved_subdomains.txt" "$PHASE_DIR/alive_hosts.txt" 2>/dev/null || touch "$PHASE_DIR/alive_hosts.txt"
fi

################################################################################
# CLEANUP AND SUMMARY
################################################################################

log_info "=== PHASE 1 SUMMARY ==="
echo "Target: $TARGET"
echo "Total Subdomains: $TOTAL_SUBS"
echo "Resolved: $RESOLVED_COUNT"
echo "Alive Hosts: ${ALIVE_COUNT:-0}"
echo ""
echo "Output files:"
echo "  - all_subdomains.txt: All discovered subdomains"
echo "  - resolved_subdomains.txt: DNS-resolved subdomains"
echo "  - alive_hosts.txt: Live HTTP/HTTPS hosts"
echo "  - httpx_alive.json: Detailed HTTPx results"
echo "  - dnsx_resolved.json: Detailed DNSx results"

# Create phase completion marker
touch "$PHASE_DIR/.completed"
log_info "Phase 1 completed successfully!"

exit 0
