# ReconX Environment Variables
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# For bash: source .env  (or export each variable)
# Python loads .env automatically via python-dotenv when running reconx.py or the API.

# -----------------------------------------------------------------------------
# Database (optional)
# -----------------------------------------------------------------------------
# RECONX_DB_PATH=reconx.db

# -----------------------------------------------------------------------------
# Phase 1: Discovery
# -----------------------------------------------------------------------------
# SecurityTrails - 50 API calls/month free
# SECURITYTRAILS_API_KEY=

# VirusTotal - 4 req/min, 500/day free
# VT_API_KEY=

# -----------------------------------------------------------------------------
# Phase 2: Intelligence
# -----------------------------------------------------------------------------
# Shodan - 100 API queries/month free
# SHODAN_API_KEY=

# Censys - free tier available
# CENSYS_API_ID=
# CENSYS_API_SECRET=

# -----------------------------------------------------------------------------
# Phase 3: Content & Phase 4
# -----------------------------------------------------------------------------
# GitHub - 5000 req/hour authenticated
# GITHUB_TOKEN=

# Pastebin API (optional)
# PASTEBIN_API_KEY=

# WPScan - 25 requests/day free (WordPress scanning)
# WPSCAN_API_TOKEN=

# -----------------------------------------------------------------------------
# Phase 5 / Threat Intel (free-tier sources)
# -----------------------------------------------------------------------------
# HaveIBeenPwned - domain/email breach check, 1 req/6 sec (free with key)
# HIBP_API_KEY=

# AbuseIPDB - 1000 checks/day free
# ABUSEIPDB_API_KEY=

# GreyNoise Community - free, basic data (unlimited with key)
# GREYNOISE_API_KEY=

# AlienVault OTX - free, 10K req/hour with key
# OTX_API_KEY=

# EmailRep - 200 queries/day free
# EMAILREP_API_KEY=

# PhishTank - free with app key (optional)
# PHISHTANK_APP_KEY=

# URLscan.io - 100 scans/day free
# URLSCAN_API_KEY=

# Pulsedive - 30 req/min, 1000/month free
# PULSEDIVE_API_KEY=

# BinaryEdge - 250 queries/month free
# BINARYEDGE_API_KEY=

# CrowdSec CTI - 50 requests/day free
# CROWDSEC_API_KEY=

# Google Safe Browsing - free, NON-COMMERCIAL USE ONLY
# GSB_API_KEY=

# -----------------------------------------------------------------------------
# Optional / Paid (leave blank to skip)
# -----------------------------------------------------------------------------
# DeHashed (paid)
# DEHASHED_EMAIL=
# DEHASHED_API_KEY=

# Intelligence X (freemium)
# INTELX_API_KEY=

# GitLab (for code search)
# GITLAB_TOKEN=

# Slack / Discord / Notifications
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
